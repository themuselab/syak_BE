# 값이 있는 항목은 그대로 써도 되는 로컬 개발 기본값이다.
# 빈 항목만 채우면 `npm run dev` 가 뜬다.

NODE_ENV=development
PORT=3000

# ── AWS RDS PostgreSQL — 사용자 데이터 ───────────────────────
# users, refresh_tokens, favorites, notification_settings, notifications
# Prod: postgresql://syak:[password]@[rds-endpoint]:5432/syak
# Docker Compose 로 띄우면 호스트는 localhost(네이티브) / db(컨테이너 내부)
DATABASE_URL=postgresql://syak:syak_dev_password@localhost:5432/syak_dev

# ── Supabase PostgreSQL — 샵/슬롯 읽기 전용 + LISTEN/NOTIFY ──
# Direct connection 필수 (port 5432). PgBouncer 풀러(6543)는 LISTEN 불가
# 위치: Supabase Dashboard → Settings → Database → Direct connection URI
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Supabase REST/Storage — 샵 조회, 마케팅 스냅샷, 이미지 버킷 ──
# SECRET_KEY 는 service_role 키다 (RLS 우회). 절대 클라이언트에 노출 금지
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SECRET_KEY=

# ── Redis — 캐시 (선택) ──────────────────────────────────────
# 비워두면 NullCacheService 로 fallback 해서 캐시 없이 동작한다
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1d

# ── Cookie ───────────────────────────────────────────────────
COOKIE_SECURE=false           # 프로덕션에서는 true (HTTPS 필수)
COOKIE_SAME_SITE=lax          # 크로스 도메인 WebView라면 none (COOKIE_SECURE=true 필요)

# ── 관리자 (admin SPA 로그인 + 세션 쿠키 syak_admin) ──────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TOKEN=openssl-rand-base64-32

# ── Apple 로그인 ─────────────────────────────────────────────
# 카카오/네이버는 클라이언트가 받은 access_token 을 서버가 검증만 하므로 키가 필요 없다.
# Apple 만 id_token 의 audience 검증에 팀 ID가 필요하다.
APPLE_TEAM_ID=

# ── FCM 푸시 — 서비스 계정 JSON 전체를 한 줄로 ────────────────
FCM_SERVICE_ACCOUNT_JSON=

# ── 내부 API 키 — GitHub Actions 스크래퍼 → 알림 dispatch ─────
INTERNAL_API_KEY=change-me-in-production

# ── 관리자 "이미지 생성" 버튼 (NVIDIA FLUX) ───────────────────
# 없으면 생성 API가 503 + 원인 메시지를 반환한다. 다른 기능은 정상 동작
# 발급: https://build.nvidia.com → black-forest-labs/flux.1-dev
NVIDIA_API_KEY_FLUX=

# ── 아래는 서버가 읽지 않는다 (scripts/marketing/*.mjs 전용) ──
# 매일 도는 수집은 GitHub Actions 에서 실행되므로 이 값들은 레포 Secrets 에 넣는다.
# 로컬에서 스크립트를 직접 돌려볼 때만 여기에 채우면 된다.
#   IG_ACCESS_TOKEN=          THREADS_ACCESS_TOKEN=
#   IG_USER_ID=               THREADS_USER_ID=
#   META_ADS_ACCESS_TOKEN=    META_AD_ACCOUNT_ID=
#   GEMINI_API_KEY=
